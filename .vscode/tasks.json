{
  "version": "2.0.0",
  "tasks": [
    // --- ENVIRONMENT TASKS ---
    {
      "label": "🚀 Start All Containers",
      "type": "shell",
      "command": "docker-compose up -d",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "🛑 Stop All Containers",
      "type": "shell",
      "command": "docker-compose down",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "🔄 Restart All Containers",
      "type": "shell",
      "command": "docker-compose restart",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    // --- FRONTEND TASKS ---
    {
      "label": "🎨 Start Frontend (Dev)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "vite.*dev server running",
          "endsPattern": "ready in"
        }
      }
    },
    {
      "label": "🏗️ Build Frontend",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "🧪 Frontend Tests (Watch)",
      "type": "shell",
      "command": "npm run test:watch",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated"
      },
      "isBackground": true
    },
    {
      "label": "🎭 E2E Tests",
      "type": "shell",
      "command": "npm run test:e2e",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      }
    },
    {
      "label": "📊 Test Coverage Report",
      "type": "shell",
      "command": "npm run test:coverage",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "✨ Lint Frontend",
      "type": "shell",
      "command": "npm run lint",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "🔍 Type Check Frontend",
      "type": "shell",
      "command": "npm run typecheck",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": ["$tsc"]
    },
    // --- DATABASE/DOCKER TASKS ---
    {
      "label": "🗄️ View Database Logs",
      "type": "shell",
      "command": "docker-compose logs -f postgres",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated"
      },
      "isBackground": true
    },
    {
      "label": "🗄️ Reset Database",
      "type": "shell",
      "command": "docker-compose down -v && docker-compose up -d postgres redis mongodb elasticsearch",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "🐳 Build Docker Images",
      "type": "shell",
      "command": "docker-compose build",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "🐍 Build Auth Service",
      "type": "shell",
      "command": "docker compose build auth-service",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "🚀 Start Auth Service",
      "type": "shell",
      "command": "docker compose up auth-service",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    // --- UTILITIES ---
    {
      "label": "🧹 Clean All",
      "type": "shell",
      "command": "npm run clean && docker system prune -f",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "📦 Install Frontend Dependencies",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "🚨 Security Audit (Frontend)",
      "type": "shell",
      "command": "npm run security:audit",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
