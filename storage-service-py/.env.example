# Application
PROJECT_NAME="Dzinza Storage Service PY"
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# MongoDB for metadata
MONGODB_URI="mongodb://dzinza_user:dzinza_password@localhost:27017/dzinza_storage?authSource=admin"
MONGODB_DATABASE_NAME="dzinza_storage"

# JWT Secret Key from Auth Service (for validating access tokens)
AUTH_SERVICE_JWT_SECRET_KEY="your_super_secret_jwt_key_here_at_least_32_bytes_long" # Must match auth-service
ALGORITHM="HS256" # Must match auth-service

# S3 Storage Configuration (Comment out if using local storage primarily)
# For AWS S3:
# S3_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY_ID"
# S3_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_ACCESS_KEY"
# S3_BUCKET_NAME="your-dzinza-s3-bucket-name"
# S3_REGION_NAME="your-aws-s3-region" # e.g., us-east-1
# S3_ENDPOINT_URL= # Leave blank for AWS S3, or specify for S3-compatible like MinIO

# For MinIO (example):
S3_ENDPOINT_URL="http://localhost:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET_NAME="dzinza-storage"
S3_REGION_NAME="us-east-1" # MinIO doesn't strictly use regions but boto3 might expect it
S3_USE_SSL=false # For local MinIO without SSL
S3_VERIFY_SSL=false # For local MinIO without SSL

S3_PRESIGNED_URL_EXPIRY_SECONDS=3600

# Local Storage (Ensure these directories exist or can be created by the app)
LOCAL_STORAGE_PATH="./uploads" # Relative to app root, or absolute path
TEMP_UPLOAD_PATH="/tmp/dzinza_uploads"

# Image Processing
IMAGE_MAX_SIZE_MB=10
IMAGE_THUMBNAIL_SIZE_PX=256
IMAGE_ALLOWED_EXTENSIONS="jpg,jpeg,png,gif,webp" # Comma-separated

# File settings
FILE_MAX_SIZE_MB=50

# CORS Origins (comma-separated, no spaces around commas)
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176"

# Observability
ENABLE_TRACING=false
JAEGER_ENDPOINT="http://localhost:4318/v1/traces"
OTEL_SERVICE_NAME="storage-service-py"

# Cleanup Service Schedule
CLEANUP_SCHEDULE_CRON="0 3 * * *" # Daily at 3 AM UTC
TEMP_FILE_MAX_AGE_HOURS=24

# Rate Limiting
RATE_LIMIT_UPLOAD_RPM=20
RATE_LIMIT_GENERAL_RPM=100
