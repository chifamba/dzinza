# Application
PROJECT_NAME="Dzinza API Gateway PY"
API_V1_PREFIX="/api"
ENVIRONMENT="development"

# Downstream Service URLs
# These are examples for Docker Compose network. Adjust for your environment (e.g., localhost for local dev).
SERVICES_AUTH_SERVICE_URL="http://auth-service-py:3002"
SERVICES_GENEALOGY_SERVICE_URL="http://genealogy-service-py:3004"
SERVICES_STORAGE_SERVICE_URL="http://storage-service-py:3005"
SERVICES_SEARCH_SERVICE_URL="http://search-service-py:3003"

# For local development without Docker internal DNS:
# SERVICES_AUTH_SERVICE_URL="http://localhost:3002"
# SERVICES_GENEALOGY_SERVICE_URL="http://localhost:3004"
# SERVICES_STORAGE_SERVICE_URL="http://localhost:3005"
# SERVICES_SEARCH_SERVICE_URL="http://localhost:3003"


# JWT Secret Key from Auth Service (OPTIONAL: if gateway validates tokens directly)
# If set, gateway will attempt to validate. If not set, it might pass tokens through or use introspection.
# AUTH_SERVICE_JWT_SECRET_KEY="your_super_secret_jwt_key_here_at_least_32_bytes_long" # Must match auth-service access token secret
# ALGORITHM="HS256"

# CORS Origins (comma-separated, no spaces around commas)
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://frontend:80"
# CORS_ALLOW_CREDENTIALS=true
# CORS_ALLOW_METHODS="GET,POST,PUT,DELETE,OPTIONS,PATCH"
# CORS_ALLOW_HEADERS="Content-Type,Authorization,X-Requested-With,X-Correlation-ID"


# Observability
ENABLE_TRACING=false
JAEGER_ENDPOINT="http://localhost:4318/v1/traces"
OTEL_SERVICE_NAME="api-gateway-py"

# Rate Limiting (RPM = Requests Per Minute)
API_RATE_LIMIT_RPM=500

# Timeout for requests to downstream services (seconds)
SERVICE_REQUEST_TIMEOUT=15.0
