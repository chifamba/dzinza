# Application
PROJECT_NAME="Dzinza Genealogy Service PY"
API_V1_STR="/api/v1" # Or match actual mount point if behind gateway
ENVIRONMENT="development"

# MongoDB
MONGODB_URI="mongodb://dzinza_user:dzinza_password@localhost:27017/dzinza_genealogy?authSource=admin"
MONGODB_DATABASE_NAME="dzinza_genealogy" # Often part of the URI, but can be separate

# Redis for Celery
REDIS_HOST="localhost"
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB_CELERY=1 # Use a different DB number if sharing Redis instance

# JWT Secret Key from Auth Service (for validating access tokens)
# This MUST match the JWT_SECRET_KEY used in the auth-service for ACCESS tokens.
# For better security, consider using asymmetric keys (RS256) in a real setup.
AUTH_SERVICE_JWT_SECRET_KEY="your_super_secret_jwt_key_here_at_least_32_bytes_long" # Must match auth-service
ALGORITHM="HS256" # Must match auth-service

# CORS Origins (comma-separated, no spaces around commas)
# Usually handled by API Gateway in a microservice architecture.
# Example: CORS_ORIGINS="http://localhost:3000,http://localhost:5173,https://your.frontend.domain"
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176"

# Observability
ENABLE_TRACING=false
JAEGER_ENDPOINT="http://localhost:4318/v1/traces"
OTEL_SERVICE_NAME="genealogy-service-py"

# Auth Service URL (if needed for direct calls, e.g., token introspection if not validating locally)
# AUTH_SERVICE_BASE_URL="http://auth-service-py:3002" # Example using Docker service name
# AUTH_SERVICE_BASE_URL="http://localhost:3002" # Example for local development without Docker network names
