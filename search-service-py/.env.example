# Application
PROJECT_NAME="Dzinza Search Service PY"
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# Elasticsearch Configuration
ELASTICSEARCH_URL="http://localhost:9200"
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=
# ELASTICSEARCH_API_KEY_ID=
# ELASTICSEARCH_API_KEY=
# ELASTICSEARCH_CA_CERTS= # Path to CA certificate file for TLS

# Index names
PERSON_INDEX_NAME="dzinza_persons"
FAMILY_TREE_INDEX_NAME="dzinza_family_trees"

# MongoDB (Optional: if search-service stores its own analytics or metadata)
# MONGODB_URI="mongodb://dzinza_user:dzinza_password@localhost:27017/dzinza_search_analytics?authSource=admin"
# MONGODB_DATABASE_NAME="dzinza_search_analytics"

# JWT Secret Key from Auth Service
AUTH_SERVICE_JWT_SECRET_KEY="your_super_secret_jwt_key_here_at_least_32_bytes_long" # Must match auth-service
ALGORITHM="HS256" # Must match auth-service

# CORS Origins
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176"

# Observability
ENABLE_TRACING=false
JAEGER_ENDPOINT="http://localhost:4318/v1/traces"
OTEL_SERVICE_NAME="search-service-py"

# Data Source Service URLs (for data pulling during indexing)
# GENEALOGY_SERVICE_BASE_URL="http://genealogy-service-py:3004" # Example for Docker network
# STORAGE_SERVICE_BASE_URL="http://storage-service-py:3005"   # Example for Docker network
GENEALOGY_SERVICE_BASE_URL="http://localhost:3004" # Example for local dev
STORAGE_SERVICE_BASE_URL="http://localhost:3005"   # Example for local dev


# Indexing settings
INDEXING_BATCH_SIZE=1000
# INDEXING_SCHEDULE_CRON="0 * * * *" # Example: Run indexing every hour at minute 0
# This would require a scheduler component like APScheduler or Celery Beat.
