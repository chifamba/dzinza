# Application
PROJECT_NAME="Dzinza Auth Service PY"
API_V1_STR="/api/v1"
ENVIRONMENT="development" # development, staging, production

# PostgreSQL Database
POSTGRES_SERVER=localhost
POSTGRES_USER=dzinza_user
POSTGRES_PASSWORD=dzinza_password
POSTGRES_DB=dzinza_auth_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM="HS256"
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY="your_super_secret_jwt_key_here_at_least_32_bytes_long"
JWT_REFRESH_SECRET_KEY="your_super_secret_jwt_refresh_key_here_at_least_32_bytes_long"

# Rate Limiting (requests per minute, unless specified otherwise)
RATE_LIMIT_GUEST_RPM=100
RATE_LIMIT_USER_RPM=200
RATE_LIMIT_LOGIN_RPM=10 # Per 15 minutes
RATE_LIMIT_FORGOT_PASSWORD_RPM=5 # Per 15 minutes

# CORS Origins (comma-separated, no spaces around commas)
# Example: CORS_ORIGINS="http://localhost:3000,http://localhost:5173,https://your.frontend.domain"
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176"

# Email settings for password reset, verification, etc.
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your_email_user"
SMTP_PASSWORD="your_email_password"
EMAILS_FROM_EMAIL="noreply@dzinza.com"
EMAILS_FROM_NAME="Dzinza Platform"

# Social Auth (Optional)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REDIRECT_URI="http://localhost:3002/api/v1/auth/google/callback" # Update port if needed
# FACEBOOK_CLIENT_ID=""
# FACEBOOK_CLIENT_SECRET=""
# FACEBOOK_REDIRECT_URI="http://localhost:3002/api/v1/auth/facebook/callback" # Update port if needed

# Observability
ENABLE_TRACING=false
JAEGER_ENDPOINT="http://localhost:4318/v1/traces"
OTEL_SERVICE_NAME="auth-service-py"

# MFA
MFA_OTP_ISSUER_NAME="DzinzaAuth"
